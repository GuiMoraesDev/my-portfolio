{
  "name": "my-portfolio",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:app\" \"pnpm dev:email\"",
    "dev:app": "next dev --turbopack",
    "dev:email": "email dev --dir './src/emails/templates' --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "check-types": "tsc --noEmit --incremental",
    "prepare": "husky",
    "test": "concurrently \"pnpm test:unit\" \"pnpm test:e2e\"",
    "test:e2e": "TEST_ENV=true pnpm exec playwright test",
    "test:e2e:ui": "TEST_ENV=true pnpm exec playwright test --ui",
    "test:unit": "jest --injectGlobals false --runInBand",
    "test:unit:watch": "jest --injectGlobals false --runInBand --watchAll",
    "test:unit:debug": "node --inspect-brk node_modules/jest/bin/jest.js --injectGlobals false --runInBand --watchAll"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.1",
    "@react-email/markdown": "^0.0.17",
    "@sentry/nextjs": "^10.30.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.12",
    "@tiptap/extension-placeholder": "^3.13.0",
    "@tiptap/extension-underline": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.21",
    "motion": "^12.23.26",
    "next": "16.0.8",
    "next-intl": "^4.5.8",
    "openai": "^6.10.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-email": "^5.0.7",
    "react-hook-form": "^7.68.0",
    "resend": "^6.6.0",
    "sanitize-html": "^2.17.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.57.0",
    "@types/lodash": "^4.17.21",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "postcss": "^8.5.6",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "whatwg-fetch": "^3.6.20"
  }
}
