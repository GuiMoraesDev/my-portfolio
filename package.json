    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.12",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.21",
    "motion": "^12.23.26",
    "next": "16.2.4",
    "next-intl": "^4.5.8",
